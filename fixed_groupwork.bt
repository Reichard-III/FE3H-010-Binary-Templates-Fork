// Not present prior to DLC waves. Possibly Sauna-related?
// usually house student and route specific characters?
struct UnknownSection5 {
	DataSection SectionHeader;
	struct UnknownData5 {
		CharID B;
		CharID A;
		TrueFalse IsEnabled;
		byte uncPadding<name="Padding?",bgcolor=cDkYellow>;
	};
    for(i=0;i<SectionHeader.NumEntries;i++){
        UnknownData5 unkDat<read=Str("%-15.15s - %-15.15s | %s",EnumToString(this.B),EnumToString(this.A), this.IsEnabled==1 ? "Enabled": "")>;
    }
};

struct File {
	FileSections Sections;
	
	FSeekNextSection(Sections);
	GroupTaskSection groupTasks<bgcolor=cDkGreen>;
	
	FSeekNextSection(Sections);
	ActivityConversationSection activityConversations<bgcolor=cBlue>;
	
	FSeekNextSection(Sections);
	GroupTaskPreferenceEntry GroupTaskPreferences<bgcolor=cPurple>;
	
	FSeekNextSection(Sections);
	UnknownSection4 unknownSect3<bgcolor=cDkRed>;
	byte padding[3]<bgcolor=cDkYellow, hidden=true>;
	
	FSeekNextSection(Sections);
	UnknownSection5 unknownSection4<bgcolor=cYellow>;
} file<open=true>;

string getGroupTaskPreference(GroupTaskPreferenceData & q){
    string out = Str("%-10.10 | Horse: %-10.10s | Armor: %-10.10s | Flying: %-10.10s", EnumToString(q.Char), EnumToString(q.StableDuty), EnumToString(q.Weeding), EnumToString(q.SkyWatch));
    
    return out;
}
string getSpecialNameList(UnknownData4 & q){
    string out = Str("%-10.10s | ", EnumToString(q.Char));
    local SaveBlockID name;
    local int i;
    for(i=0; i<45; i++){
        if(SpecialCharacter[i]==1){
            name = i;
            out += Str("%-3.3s ",EnumToString(name));
        }
    }
    return out;
}